# 工地監工 Pro — Secrets 範本
#
# 用法：複製這個檔案，改名為 secrets.toml（去掉 .example），
# 填入你自己 Supabase 與 Google 帳戶的真實資料。
#
# ⚠️ secrets.toml 本身「絕對不要」加進 git / 上傳到 GitHub（.gitignore 已排除）。
# 部署到 Streamlit Community Cloud 時，改成把同樣內容貼到
# App 右下角「⋮」→ Settings → Secrets 那個欄位裡，不要用檔案上傳。

[supabase]
url = "https://your-project.supabase.co"
service_role_key = "your-service-role-key"

[gdrive]
# 下面四個值都是執行一次 gdrive_oauth_setup.py（見同資料夾說明）之後，
# 終端機印出來的內容，直接複製貼上即可。
root_folder_id = "your-google-drive-folder-id"
client_id = "your-oauth-client-id"
client_secret = "your-oauth-client-secret"
refresh_token = "your-oauth-refresh-token"
